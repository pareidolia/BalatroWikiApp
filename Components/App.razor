<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["BalatroWikiApp.styles.css"]" />
    
    <link href="_content/AntDesign/css/ant-design-blazor.css" rel="stylesheet" />
    <script src="_content/AntDesign/js/ant-design-blazor.js"></script>

    <ImportMap />
    <link rel="icon" type="image/png" href="balatroicon.jfif" />
    <HeadOutlet @rendermode="RenderModeForPage" />
</head>

<body>
    <Routes @rendermode="RenderModeForPage" />
    <script src="_framework/blazor.web.js"></script>
    
    <AntDesign.AntContainer />
</body>

</html>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    // Cette logique est correcte pour l'Identity .NET 8
    // Elle permet aux pages /Account de fonctionner en SSR statique (pour les Cookies)
    // Et au reste du Wiki d'être interactif.
    private IComponentRenderMode? RenderModeForPage =>
      HttpContext.Request.Path.StartsWithSegments("/Account")
        ? null
        : InteractiveServer;
}