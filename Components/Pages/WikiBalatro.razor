@page "/wikibalatro"
@rendermode InteractiveServer
@using AntDesign

<h2>Wiki Balatro</h2>
<br />

@if (!string.IsNullOrEmpty(Sections[0]?.SectionName))
{
    <br />
    <div style="grid-column: span 4; width: 100%;">
        <h4>@Sections[0].SectionName</h4>
    </div>
    <br />
}
<AntList Grid="grid" DataSource="@Sections[0].Items">
    <ListItem>
        <a href="@context.Link" class="card-link">
            <Card Bordered Class="card-avec-image">
                <Body>
                    <div class="card-content">
                        <div class="card-image">
                            @switch (context.Title)
                            {
                                case "Hand":
                                    <Image Src="images/ConceptImages/Hand.png" />
                                    break;

                                case "Deck":
                                    <Image Src="images/ConceptImages/Deck.png" />
                                    break;

                                case "Card":
                                    <Image Src="images/ConceptImages/Card.png" />
                                    break;

                                case "Joker":
                                    <Image Src="images/ConceptImages/Joker.png" />
                                    break;

                                case "Blind":
                                    <Image Src="images/ConceptImages/Blind.jfif" />
                                    break;

                                case "Tag":
                                    <Image Src="images/ConceptImages/Tag.jfif" />
                                    break;
                            }
                        </div>
                        <div class="card-info">
                            <div class="card-title">@context.Title</div>
                        </div>
                    </div>
                </Body>
            </Card>
        </a>
    </ListItem>
</AntList>

@if (!string.IsNullOrEmpty(Sections[1]?.SectionName))
{
    <br />
    <div style="grid-column: span 4; width: 100%;">
        <h4>@Sections[1].SectionName</h4>
    </div>
    <br />
}
<AntList Grid="grid" DataSource="@Sections[1].Items">
    <HeadContent>

    </HeadContent>

    <ListItem>
        <a href="@context.Link" class="card-link">
            <Card Bordered Class="card-avec-image">
                <Body>
                    <div class="card-content">
                        <div class="card-image">
                            @switch (context.Title)
                            {
                                case "Booster Pack":
                                    <Image Src="images/ConceptImages/Boosterpack.jfif" />
                                    break;

                                case "Consumable Cards":
                                    <Image Src="images/ConceptImages/Tarot.png" />
                                    break;

                                case "Seal":
                                    <Image Src="images/ConceptImages/Seal.png" />
                                    break;

                                case "Voucher":
                                    <Image Src="images/ConceptImages/Voucher.png" />
                                    break;
                            }
                        </div>
                        <div class="card-info">
                            <div class="card-title">@context.Title</div>
                        </div>
                    </div>
                </Body>
            </Card>
        </a>
    </ListItem>
</AntList>
@if (!string.IsNullOrEmpty(Sections[2]?.SectionName))
{
    <br />
    <div style="grid-column: span 4; width: 100%;">
        <h4>@Sections[2].SectionName</h4>
    </div>
    <br />
}
<AntList Grid="grid" DataSource="@Sections[2].Items">
    <HeadContent>
    </HeadContent>
    <ListItem>
        <a href="@context.Link" class="card-link">
            <Card Bordered Class="card-avec-image">
                <Body>
                    <div class="card-content">
                        <div class="card-image">
                            @switch (context.Title)
                            {
                                case "Edition":
                                    <Image Src="images/ConceptImages/Edition.jfif" />
                                    break;

                                case "Enhanced":
                                    <Image Src="images/ConceptImages/Enhanced.jfif" />
                                    break;

                                case "Sticker":
                                    <Image Src="images/ConceptImages/Sticker.png" />
                                    break;
                            }
                        </div>
                        <div class="card-info">
                            <div class="card-title">@context.Title</div>
                        </div>
                    </div>
                </Body>
            </Card>
        </a>
    </ListItem>
</AntList>
<style>
    .card-avec-image {
        background-image: url('/images/Background/fond_balatro.jpg');
        background-size: cover;
        min-height: 180px;
        color: white;
        border: 2px solid black;
        display: flex;
        flex-direction: column;
    }

        .card-avec-image .ant-card-head-title {
            font-weight: bold;
            text-align: center;
            color: white;
        }

    .card-link {
        display: block;
        color: inherit;
        text-decoration: none;
        width: 100%;
    }

        .card-link:focus,
        .card-link:hover {
            text-decoration: none;
        }

        .card-avec-image .ant-card-body {
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0.75rem;
            min-height: 180px;
        }

    .card-content {
        display: flex;
        width: 100%;
        align-items: center;
        justify-content: center;
    }

    .card-image {
        flex: 0 0 35%;
        display: flex;
        justify-content: center;
        align-items: center;
    }

        .card-image img {
            max-width: 100%;
            max-height: 120px;
            object-fit: contain;
        }

    .card-info {
        flex: 1 1 auto;
        padding-left: 12px;
        display: flex;
        align-items: center;
    }

    .card-title {
        font-weight: bold;
        color: white;
        font-size: 1.1rem;
    }

    ::deep .ant-list {
        width: 100%;
    }

    ::deep .ant-list-grid {
        width: 100%;
    }

    ::deep .ant-list-item {
        width: 100%;
    }
</style>

@code {

    public ListGridType grid = new ListGridType { Gutter = 16, Column = 4 };

    public class Section
    {
        public string SectionName { get; set; }
        public List<BasicItem> Items { get; set; }
    }

    public List<Section> Sections = new List<Section>
    {

        new Section
        {
            SectionName = "Game concepts",
            Items =  new List<BasicItem>
        {
            new BasicItem { Title = "Hand", Link = "/hand" },
            new BasicItem { Title = "Deck", Link = "/deck" },
            new BasicItem { Title = "Card", Link = "/card" },
            new BasicItem { Title = "Joker", Link = "/joker" },
            new BasicItem { Title = "Blind", Link = "/blind" },
            new BasicItem { Title = "Tag", Link = "/tag" },
        }
        },

        new Section
        {
            SectionName = "Consumable",
            Items = new List<BasicItem>
            {
                new BasicItem { Title = "Booster Pack", Link = "/boosterpack"},
                new BasicItem { Title = "Consumable Cards", Link = "/consumable"},
                new BasicItem { Title = "Seal", Link = "/seal"},
                new BasicItem { Title = "Voucher", Link = "/voucher"},
            }
        },

        new Section
        {
            SectionName = "Special effects",
            Items = new List<BasicItem>
            {
                new BasicItem { Title = "Edition", Link = "/edition"},
                new BasicItem { Title = "Enhanced", Link = "/enhanced"},
                new BasicItem { Title = "Sticker", Link = "/sticker"},
            }
        },
    };

    public class BasicItem
    {
        public string Title { get; set; }
        public string Link { get; set; }
        
    }

}